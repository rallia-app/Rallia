# =====================================
# Supabase Configuration
# =====================================
# Copy this file to .env and fill in your actual values
# Get these from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =====================================
# Google Configuration
# =====================================
# Google Sign-In
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable Google Sign-In API
# 3. Create OAuth 2.0 credentials (Web and iOS client IDs)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Google Maps / Places API
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# =====================================
# PostHog Analytics
# =====================================
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =====================================
# Mapbox
# =====================================
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# =====================================
# Sentry Error Tracking
# =====================================
# Get the DSN from: Sentry Dashboard → Project Settings → Client Keys (DSN)
# Get the auth token from: Sentry → Settings → Auth Tokens
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token
